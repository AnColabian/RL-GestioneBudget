<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Dialog id="dialogAssegnazioneBudgetUO" title="{viewModel>/dialogUOTitolo}" contentWidth="32rem" resizable="false" stretch="false">
        <content>
            <form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12" columnsXL="1" columnsL="1" columnsM="1" class="sapUiNoMarginBegin sapUiNoMarginEnd sapUiSmallMarginTopBottom">
                <form:content>
                    <Label text="{i18n>lblEsercizio}"/>
                    <Text text="{viewModel>/dialogUO/ESERCIZIO}"/>
                    <Label text="{i18n>lblCdCDG}"/>
                    <Text text="{viewModel>/dialogUO/CENTRO_DI_COSTO_DG}"/>
                    <Label text="{i18n>lblCdCUO}" required="true"/>
                    <Input width="30rem" id="inpCdCUO" value="{viewModel>/dialogUO/CENTRO_DI_COSTO_UO}" maxLength="10" placeholder="{i18n>phCdCUO}" enabled="{viewModel>/dialogUOCdCUOEditable}" valueState="{viewModel>/dialogUO/CdCUOValueState}" valueStateText="{viewModel>/dialogUO/CdCUOValueStateText}" liveChange=".onCdCUOLiveChange"/>
                    <Label text="{i18n>lblImportoAssegnato}" required="true"/>
                    <Input width="30rem" id="inpImportoUO" value="{viewModel>/dialogUO/IMPORTO_ASSEGNATO}" maxLength="23" textAlign="End" placeholder="{i18n>phImporto}" valueState="{viewModel>/dialogUO/ImportoValueState}" valueStateText="{viewModel>/dialogUO/ImportoValueStateText}" liveChange=".onImportoUOLiveChange"/>
                </form:content>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="{i18n>btnSalva}" type="Emphasized" press=".onSalvaUO"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>btnAnnulla}" press=".onAnnullaUO"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>